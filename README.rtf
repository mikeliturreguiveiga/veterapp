\uc0\u9474    
\f1 \'a9\'c0
\f0 \uc0\u9472 \u9472  omg/                  # Im\'e1genes y recursos gr\'e1ficos\
\uc0\u9474    \u9492 \u9472 \u9472  js/                   # L\'f3gica de cliente (agenda.js, usuarios.js, mascotas.js)\

\f1 \'a9\'c0
\f0 \uc0\u9472 \u9472  cliente/                  # \'c1rea privada para clientes (cliente.php)\

\f1 \'a9\'c0
